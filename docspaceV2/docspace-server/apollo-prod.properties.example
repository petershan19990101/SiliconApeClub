# DocSpace Apollo production template
#
# Usage
# 1. Copy this file to `apollo-prod.properties` on the target server.
# 2. Fill in the real production values.
# 3. Keep bootstrap properties on the deploy host.
# 4. Create the namespace properties in Apollo Portal under the `application` namespace.

# =========================
# Deploy host bootstrap properties
# These are required before the app can pull configuration from Apollo.
# =========================
app.id=docspace-server
apollo.meta=http://apollo-meta.prod.example.com:8080
apollo.bootstrap.enabled=true
apollo.bootstrap.eagerLoad.enabled=true
apollo.bootstrap.namespaces=application

# =========================
# Apollo Portal -> application namespace
# Maintain the following keys in Apollo Portal.
# =========================
spring.application.name=docspace-server
server.port=8080
docspace.cors.allow-credentials=true
docspace.cors.max-age=1800
docspace.cors.allowed-origins=https://fssit.example.com,https://fsuat.example.com,https://fssandbox.example.com
docspace.cors.allowed-methods=GET,POST,PUT,DELETE,OPTIONS
docspace.cors.allowed-headers=*
docspace.cors.exposed-headers=Authorization

spring.datasource.url=jdbc:postgresql://postgres-prod.example.com:5432/docspace
spring.datasource.username=docspace
spring.datasource.password=replace-with-real-password
spring.datasource.driver-class-name=org.postgresql.Driver

spring.redis.password=replace-with-real-password
spring.redis.timeout=3000
spring.redis.cluster.nodes=redis-prod-1:6379,redis-prod-2:6379,redis-prod-3:6379,redis-prod-4:6379,redis-prod-5:6379,redis-prod-6:6379
spring.redis.cluster.max-redirects=3

rocketmq.name-server=rocketmq-namesrv-1:9876;rocketmq-namesrv-2:9876
rocketmq.producer.group=docspace-server-producer
rocketmq.producer.send-message-timeout=3000

docspace.jwt.secret=replace-with-strong-jwt-secret-at-least-32-chars
docspace.jwt.expire-seconds=7200

docspace.redis.cache-enabled=true
docspace.redis.cache-ttl-seconds=300

docspace.rocketmq.enabled=true
docspace.rocketmq.topic.document-lifecycle=docspace.document.lifecycle

docspace.minio.enabled=true
docspace.minio.endpoint=https://minio-prod.example.com
docspace.minio.access-key=replace-with-real-access-key
docspace.minio.secret-key=replace-with-real-secret-key
docspace.minio.bucket=docspace

docspace.preview.libreoffice-command=soffice
docspace.preview.libreoffice-timeout-seconds=120

spring.flyway.enabled=true
spring.flyway.locations=classpath:db/migration-postgres
logging.file.name=logs/docspace-server.log

# Optional switches
# docspace.redis.cache-enabled=false
# docspace.rocketmq.enabled=false
# docspace.minio.enabled=false
